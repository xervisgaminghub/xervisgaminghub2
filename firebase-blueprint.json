{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "age": { "type": "integer" },
        "phone": { "type": "string" },
        "username": { "type": "string" },
        "points": { "type": "integer" },
        "lastSpinAt": { "type": "string", "format": "date-time" },
        "level": { "type": "string", "enum": ["Silver", "Bronze", "Gold", "Platinum", "Diamond", "Crown", "Elite Crown"] },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "age", "username", "points", "level", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Purchase records for top-ups",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "price": { "type": "number" },
        "uid": { "type": "string", "description": "Game UID" },
        "transactionId": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string", "enum": ["processing", "completed", "failed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productName", "price", "uid", "transactionId", "paymentMethod", "status", "createdAt"]
    },
    "PointTransaction": {
      "title": "PointTransaction",
      "description": "History of point earnings and spending",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "integer" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "reason", "createdAt"]
    },
    "Referral": {
      "title": "Referral",
      "description": "Referral tracking",
      "type": "object",
      "properties": {
        "referrerId": { "type": "string" },
        "referredUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["referrerId", "referredUserId", "createdAt"]
    },
    "TournamentRegistration": {
      "title": "TournamentRegistration",
      "description": "Registration for tournament",
      "type": "object",
      "properties": {
        "tournamentId": { "type": "string" },
        "userId": { "type": "string" },
        "teamName": { "type": "string" },
        "player1Name": { "type": "string" },
        "player1UID": { "type": "string" },
        "player2Name": { "type": "string" },
        "player2UID": { "type": "string" },
        "player3Name": { "type": "string" },
        "player3UID": { "type": "string" },
        "player4Name": { "type": "string" },
        "player4UID": { "type": "string" },
        "phone": { "type": "string" },
        "transactionId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "denied"] },
        "denyReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tournamentId", "userId", "teamName", "player1Name", "player1UID", "phone", "status", "createdAt"]
    },
    "Tournament": {
      "title": "Tournament",
      "description": "Information about a competitive gaming event.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "winnerTeam": { "type": "string" },
        "victoryDate": { "type": "string" },
        "scrollingText": { "type": "string" },
        "rules": { "type": "string" },
        "schedule": { "type": "string" },
        "startTime": { "type": "string" },
        "entryFee": { "type": "string" },
        "platform": { "type": "string" },
        "prizePool": { "type": "string" },
        "operationalIntel": { "type": "string" },
        "registrationActive": { "type": "boolean" },
        "status": { "type": "string", "enum": ["upcoming", "active", "completed"] },
        "isPaid": { "type": "boolean" },
        "entryFeeAmount": { "type": "number" },
        "roomId": { "type": "string" },
        "password": { "type": "string" },
        "isIdPassLocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "registrationActive", "updatedAt", "isPaid", "isIdPassLocked"]
    },
    "EsportsTeam": {
      "title": "EsportsTeam",
      "description": "An esports team recruiting members",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "recruitmentOpen": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "recruitmentOpen"]
    },
    "TeamApplication": {
      "title": "TeamApplication",
      "description": "An application submitted by a player to join an esports team",
      "type": "object",
      "properties": {
        "teamId": { "type": "string" },
        "teamName": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "name": { "type": "string" },
        "inGameName": { "type": "string" },
        "uid": { "type": "string" },
        "idLevel": { "type": "string" },
        "preferredRole": { "type": "string" },
        "whatsAppNumber": { "type": "string" },
        "previousExperience": { "type": "string" },
        "prevTeamName": { "type": "string" },
        "prevRole": { "type": "string" },
        "prevPlayDuration": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "hold", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["teamId", "teamName", "userId", "name", "inGameName", "uid", "idLevel", "preferredRole", "whatsAppNumber", "previousExperience", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Top-up order documents"
    },
    "/points/{transactionId}": {
      "schema": "PointTransaction",
      "description": "Point history logs"
    },
    "/referrals/{referralId}": {
      "schema": "Referral",
      "description": "Referral relationship records"
    },
    "/tournamentRegistrations/{registrationId}": {
      "schema": "TournamentRegistration",
      "description": "Registration for tournament"
    },
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Tournament metadata and winner info"
    },
    "/esportsTeams/{teamId}": {
      "schema": "EsportsTeam",
      "description": "Esports teams and recruitment options"
    },
    "/teamApplications/{applicationId}": {
      "schema": "TeamApplication",
      "description": "Esports team join applications from users"
    }
  }
}

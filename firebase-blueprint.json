{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "age": { "type": "integer" },
        "phone": { "type": "string" },
        "username": { "type": "string" },
        "points": { "type": "integer" },
        "lastSpinAt": { "type": "string", "format": "date-time" },
        "level": { "type": "string", "enum": ["Silver", "Bronze", "Gold", "Platinum", "Diamond", "Crown", "Elite Crown"] },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "age", "username", "points", "level", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Purchase records for top-ups",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "price": { "type": "number" },
        "uid": { "type": "string", "description": "Game UID" },
        "transactionId": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string", "enum": ["processing", "completed", "failed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productName", "price", "uid", "transactionId", "paymentMethod", "status", "createdAt"]
    },
    "PointTransaction": {
      "title": "PointTransaction",
      "description": "History of point earnings and spending",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "integer" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "reason", "createdAt"]
    },
    "Referral": {
      "title": "Referral",
      "description": "Referral tracking",
      "type": "object",
      "properties": {
        "referrerId": { "type": "string" },
        "referredUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["referrerId", "referredUserId", "createdAt"]
    },
    "TournamentRegistration": {
      "title": "TournamentRegistration",
      "description": "Registration for tournament",
      "type": "object",
      "properties": {
        "tournamentId": { "type": "string" },
        "userId": { "type": "string" },
        "teamName": { "type": "string" },
        "player1": { "type": "string" },
        "player2": { "type": "string" },
        "player3": { "type": "string" },
        "player4": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "denied"] },
        "denyReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tournamentId", "userId", "teamName", "player1", "player2", "player3", "player4", "phone", "status", "createdAt"]
    },
    "Tournament": {
      "title": "Tournament",
      "description": "Information about a competitive gaming event.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "winnerTeam": { "type": "string" },
        "victoryDate": { "type": "string" },
        "scrollingText": { "type": "string" },
        "rules": { "type": "string" },
        "schedule": { "type": "string" },
        "startTime": { "type": "string" },
        "entryFee": { "type": "string" },
        "platform": { "type": "string" },
        "prizePool": { "type": "string" },
        "registrationActive": { "type": "boolean" },
        "status": { "type": "string", "enum": ["upcoming", "active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "registrationActive", "updatedAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Global internal announcements shown to users in the app",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "success", "event"] },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type", "active", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Top-up order documents"
    },
    "/points/{transactionId}": {
      "schema": "PointTransaction",
      "description": "Point history logs"
    },
    "/referrals/{referralId}": {
      "schema": "Referral",
      "description": "Referral relationship records"
    },
    "/tournamentRegistrations/{registrationId}": {
      "schema": "TournamentRegistration",
      "description": "Registration for tournament"
    },
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Tournament metadata and winner info"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Global internal announcements"
    }
  }
}
